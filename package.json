{
  "name": "@requesty/n8n-nodes-requesty",
  "version": "1.1.2",
  "description": "n8n community node for Requesty: access 300+ AI models through one unified gateway with structured output, web search and reasoning.",
  "license": "MIT",
  "homepage": "https://requesty.ai",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Requesty",
    "email": "support@requesty.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/requestyai/n8n-requesty.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "jest",
    "prepack": "n8n-node build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RequestyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LmChatRequesty/LmChatRequesty.node.js",
      "dist/nodes/ImageGenRequesty/ImageGenRequesty.node.js"
    ]
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@n8n/node-cli": "*",
    "@types/jest": "^30.0.0",
    "eslint": "9.32.0",
    "jest": "^30.4.2",
    "n8n-workflow": "^2.22.1",
    "prettier": "3.6.2",
    "ts-jest": "^29.4.11",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@n8n/ai-node-sdk": ">=0.10.0",
    "n8n-workflow": "*"
  }
}
